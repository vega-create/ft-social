---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import AdSense from '../components/AdSense.astro';
import TweetComposer from '../components/tools/TweetComposer';
---
<BaseLayout>
  <SEO slot="head" title="Tweet Composer" description="Compose tweets with character count and thread support." />
  <div class="max-w-4xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-primary-600">Home</a> <span class="mx-2">›</span> <span class="text-gray-900">Tweet Composer</span></nav>
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Tweet Composer</h1>
    <TweetComposer client:load />
    <AdSense slot="bottom" />
  </div>
</BaseLayout>