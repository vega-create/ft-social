---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import AdSense from '../components/AdSense.astro';
import TextToImage from '../components/tools/TextToImage';
---
<BaseLayout>
  <SEO slot="head" title="Text to Image" description="Create quote images and text posts for social sharing." />
  <div class="max-w-4xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-primary-600">Home</a> <span class="mx-2">›</span> <span class="text-gray-900">Text to Image</span></nav>
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Text to Image</h1>
    <TextToImage client:load />
    <AdSense slot="bottom" />
  </div>
</BaseLayout>