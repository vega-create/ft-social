---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import AdSense from '../components/AdSense.astro';
import CharCounter from '../components/tools/CharCounter';
---
<BaseLayout>
  <SEO slot="head" title="Character Counter" description="Count characters with limits for each social platform." />
  <div class="max-w-4xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-primary-600">Home</a> <span class="mx-2">›</span> <span class="text-gray-900">Character Counter</span></nav>
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Character Counter</h1>
    <CharCounter client:load />
    <AdSense slot="bottom" />
  </div>
</BaseLayout>