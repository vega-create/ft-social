---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import AdSense from '../components/AdSense.astro';
import LinkInBio from '../components/tools/LinkInBio';
---
<BaseLayout>
  <SEO slot="head" title="Link in Bio Page" description="Create a simple link-in-bio page with multiple links." />
  <div class="max-w-4xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-primary-600">Home</a> <span class="mx-2">›</span> <span class="text-gray-900">Link in Bio Page</span></nav>
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Link in Bio Page</h1>
    <LinkInBio client:load />
    <AdSense slot="bottom" />
  </div>
</BaseLayout>