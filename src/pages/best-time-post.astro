---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import AdSense from '../components/AdSense.astro';
import BestTimePost from '../components/tools/BestTimePost';
---
<BaseLayout>
  <SEO slot="head" title="Best Time to Post" description="Find optimal posting times for each platform." />
  <div class="max-w-4xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-primary-600">Home</a> <span class="mx-2">›</span> <span class="text-gray-900">Best Time to Post</span></nav>
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Best Time to Post</h1>
    <BestTimePost client:load />
    <AdSense slot="bottom" />
  </div>
</BaseLayout>